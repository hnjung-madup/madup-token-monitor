{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "madup-token-monitor",
  "version": "0.1.14",
  "identifier": "com.madup.token-monitor",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "매드업 토큰 모니터",
        "width": 460,
        "height": 760,
        "decorations": false,
        "resizable": false,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "shadow": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["madup-token-monitor"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJEM0IwQ0VCRjUyQ0NEQkEKUldTNnpTejE2d3c3TGRDaElBYkdyRUJCVnpkd1F0Y1FaWmlxT0l4VTl1Ty8wdFVQK2F3U3NCeVMK",
      "endpoints": [
        "https://github.com/hnjung-madup/madup-token-monitor/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
