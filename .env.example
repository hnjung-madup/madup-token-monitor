# Supabase
# Dashboard > Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co

# "Publishable key" (sb_publishable_...) — 클라이언트에서 안전하게 사용 가능 (RLS로 보호됨)
# 새 Supabase Dashboard 명명: Publishable key (예전 anon key)
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ⚠️  Secret key (sb_secret_...) 는 여기에 절대 넣지 마세요. 서버 전용. Git 커밋 시 DB 어드민 권한 노출.

# Slack OAuth
# Supabase Dashboard > Authentication > Providers > Slack(OIDC) 에서 Client ID/Secret 입력
# 앱 측 환경변수에는 Slack 키를 두지 않습니다.
